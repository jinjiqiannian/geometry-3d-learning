VITE_API_URL=https://geometry-3d-learning-production.up.railway.app
# ── Supabase（可选：配置后启用账号系统和云端同步）──
# 1. 前往 https://supabase.com 创建项目
# 2. 在项目 Settings → API 中复制 URL 和 anon key
# 3. 取消注释下面两行并填入实际值
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# ── Stripe（可选：配置后启用付费订阅）──
# 在 Supabase Edge Functions 中部署 stripe-checkout 和 stripe-portal
# VITE_STRIPE_PRICE_PRO_MONTHLY=price_xxx
# VITE_STRIPE_PRICE_PRO_YEARLY=price_xxx
# VITE_STRIPE_PRICE_TEACHER_MONTHLY=price_xxx
# VITE_STRIPE_PRICE_TEACHER_YEARLY=price_xxx
