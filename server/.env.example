# ═══════════════════════════════════════════════
#  MathViz Server — 环境变量配置
#  复制此文件为 .env 并填入实际值
# ═══════════════════════════════════════════════

PORT=3001
NODE_ENV=development

# Supabase (service_role key — 仅用于管理操作)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Supabase anon key — 用于用户数据查询（受 RLS 保护）
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT 签名密钥（请使用 openssl rand -hex 32 生成）
JWT_SECRET=your-256-bit-secret-change-me-in-production
JWT_EXPIRES_IN=7d

# DeepSeek AI API
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Stripe 支付
# 测试密钥: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# 前端地址 (CORS 白名单)
FRONTEND_URL=http://localhost:5179
